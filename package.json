{
  "name": "hexatuneapp",
  "version": "0.0.0",
  "description": "Semantic-release metadata for hexaTuneApp",
  "private": true,
  "repository": "https://github.com/hTuneSys/hexaTuneApp",
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/commit-analyzer": "^9.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^9.0.0",
    "@semantic-release/release-notes-generator": "^10.0.0",
    "husky": "^9.1.7",
    "semantic-release": "^22.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "flutter:run": "cd hexatuneapp && flutter run",
    "flutter:format": "cd hexatuneapp && dart format lib test",
    "flutter:analyze": "cd hexatuneapp && flutter analyze",
    "flutter:test": "cd hexatuneapp && flutter test",
    "flutter:build": "cd hexatuneapp && dart run build_runner build --delete-conflicting-outputs",
    "flutter:clean": "cd hexatuneapp && flutter clean && flutter pub get"
  }
}
