#include? "Pods/Target Support Files/Pods-Runner/Pods-Runner.release.xcconfig"
#include "Generated.xcconfig"

// Export Rust FFI symbols so dlsym(RTLD_DEFAULT) can find them at runtime.
//
// Problem: Two Rust staticlibs (DSP + Proto) share runtime symbols
// (___rust_alloc etc.). Force-loading DSP + normally linking Proto causes
// 1 duplicate symbol in ld_prime (Xcode 16). DEAD_CODE_STRIPPING=YES
// masks the duplicate but also strips ALL Rust FFI code (832K binary).
//
// Solution:
//   DEAD_CODE_STRIPPING=NO    — keeps Rust FFI code alive
//   -ld_classic                — legacy linker silently resolves the duplicate
//   -export_dynamic            — preserves global symbols through LTO
//   EXPORTED_SYMBOLS_FILE      — places FFI symbols into the Mach-O export trie
//   LD_GENERATE_MAP_FILE       — produces link map for CI diagnostics
//
// Long-term fix: combine DSP + Proto into one Rust crate (one staticlib),
// eliminating duplicate runtime symbols. Then remove -ld_classic and
// -force_load, switch back to ld_prime with DEAD_CODE_STRIPPING=YES.
DEAD_CODE_STRIPPING = NO
EXPORTED_SYMBOLS_FILE = $(SRCROOT)/Runner/ffi_exports.exp
LD_GENERATE_MAP_FILE = YES
LD_MAP_FILE_PATH = $(BUILD_DIR)/ffi-link-map-$(CURRENT_ARCH).txt
OTHER_LDFLAGS = $(inherited) -Wl,-ld_classic -Wl,-export_dynamic

PRODUCT_BUNDLE_IDENTIFIER = com.hexatune.hexatuneapp
DEVELOPMENT_TEAM = 3B6JLK5JN9
CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = Apple Distribution
PROVISIONING_PROFILE_SPECIFIER = hexaTune AppStore

