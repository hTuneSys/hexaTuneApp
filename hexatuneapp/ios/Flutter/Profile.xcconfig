#include? "Pods/Target Support Files/Pods-Runner/Pods-Runner.profile.xcconfig"
#include "Generated.xcconfig"

// Export Rust FFI symbols so dlsym(RTLD_DEFAULT) can find them at runtime.
// Three flags work together:
//   -export_dynamic: preserves global symbols through LTO (prevents inlining)
//   -exported_symbols_list: places FFI symbols into the Mach-O export trie
//   DEAD_CODE_STRIPPING=NO: prevents cascade removal of Rust internal deps
//
// Without DEAD_CODE_STRIPPING=NO, -exported_symbols_list marks unlisted symbols
// as __private_extern__, and dead code stripping removes them — causing FFI
// entry points to lose their dependencies and be stripped too (2.1M → 832K).
OTHER_LDFLAGS = $(inherited) -Wl,-export_dynamic -Wl,-exported_symbols_list,$(SRCROOT)/Runner/ffi_exports.exp
DEAD_CODE_STRIPPING = NO

PRODUCT_BUNDLE_IDENTIFIER = com.hexatune.hexatuneapp
DEVELOPMENT_TEAM = 3B6JLK5JN9
CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = Apple Distribution
PROVISIONING_PROFILE_SPECIFIER = hexaTune AppStore
