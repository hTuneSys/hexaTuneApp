#include? "Pods/Target Support Files/Pods-Runner/Pods-Runner.debug.xcconfig"
#include "Generated.xcconfig"

// Export Rust FFI symbols so dlsym(RTLD_DEFAULT) can find them at runtime.
// See Release.xcconfig for detailed explanation of this configuration.
DEAD_CODE_STRIPPING = NO
EXPORTED_SYMBOLS_FILE = $(SRCROOT)/Runner/ffi_exports.exp
LD_GENERATE_MAP_FILE = YES
LD_MAP_FILE_PATH = $(SRCROOT)/build/Runner-FFI-LinkMap-$(CURRENT_ARCH).txt
OTHER_LDFLAGS = $(inherited) -Wl,-ld_classic -Wl,-export_dynamic
