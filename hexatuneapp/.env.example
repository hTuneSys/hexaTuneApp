# hexaTuneApp — Environment Configuration Template
#
# Copy this file to `.env.{environment}` and fill in the values:
#   cp .env.example .env.dev
#   cp .env.example .env.test
#   cp .env.example .env.stage
#   cp .env.example .env.prod
#
# Then build with:
#   flutter run --dart-define-from-file=.env.dev
#
# All values are injected at compile time via `--dart-define-from-file`.
# See `lib/src/core/config/env.dart` for how they are consumed.

# Environment name: dev | test | stage | prod
ENVIRONMENT=dev

# Backend API base URL (no trailing slash)
API_BASE_URL=

# Google Sign-In: server (web) client ID for requesting ID tokens.
# Get this from Google Cloud Console → APIs & Services → Credentials.
GOOGLE_OAUTH_SERVER_CLIENT_ID=

# Apple Sign-In: Service ID for web/Android redirect flow.
# Get this from Apple Developer → Certificates, Identifiers & Profiles.
APPLE_SIGNIN_SERVICE_ID=

# Apple Sign-In: Redirect URL for web/Android flow.
APPLE_SIGNIN_REDIRECT_URL=

# Application bundle identifier (default: com.hexatune.hexatuneapp).
# Override only if using a different package name.
# APP_BUNDLE_ID=com.hexatune.hexatuneapp
